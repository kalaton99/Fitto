      "icons": [{ "src": "/icon-meal.png", "sizes": "96x96" }]
    },
    {
      "name": "AI Coach",
      "short_name": "Coach",
      "description": "AI beslenme koçu ile sohbet",
      "url": "/?action=ai-coach",
      "icons": [{ "src": "/icon-ai.png", "sizes": "96x96" }]
    },
    {
      "name": "Su Takibi",
      "short_name": "Su",
      "description": "Su tüketimini kaydet",
      "url": "/hydration",
      "icons": [{ "src": "/icon-water.png", "sizes": "96x96" }]
    }
  ],
  "handle_links": "preferred",
